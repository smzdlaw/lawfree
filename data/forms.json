                "label": "利息（週年利率 %）",
                "type": "number",
                "required": true,
                "placeholder": "若無特別約定則可填寫6%"
              },
              {
                "name": "interestStartDate",
                "label": "利息起算日",
                "type": "date",
                "required": true
              },
              {
                "name": "court",
                "label": "法院",
                "type": "text",
                "required": true,
                "placeholder": "例如：臺灣臺中地方法院"
              }
            ]
          }
        ]
      }
    ]
  },
  "divorce": {
    "title": "離婚協議書",
    "steps": [
      {
        "id": 1,
        "label": "填寫資料",
        "sections": [
          {
            "title": "男方資料",
            "prefix": "husband",
            "fields": [
              {
                "name": "name",
                "label": "姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：王小明"
              },
              {
                "name": "idNumber",
                "label": "身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：A123456789"
              },
              {
                "name": "address",
                "label": "地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "女方資料",
            "prefix": "wife",
            "fields": [
              {
                "name": "name",
                "label": "姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：陳小美"
              },
              {
                "name": "idNumber",
                "label": "身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：B223456789"
              },
              {
                "name": "address",
                "label": "地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "協議內容",
            "prefix": "agreement",
            "fields": [
              {
                "name": "hasMinorChildren",
                "label": "是否有未成年子女",
                "type": "select",
                "required": true,
                "options": [
                  {
                    "value": "",
                    "label": "請選擇"
                  },
                  {
                    "value": "yes",
                    "label": "有未成年子女"
                  },
                  {
                    "value": "no",
                    "label": "無未成年子女"
                  }
                ]
              },
              {
                "name": "childrenAgreement",
                "label": "未成年子女約定",
                "type": "textarea",
                "required": false,
                "placeholder": "例如：若有未成年子女可填寫子女姓名、生日及身分證字號。如無子女，此欄可不填。"
              },
              {
                "name": "supportAgreement",
                "label": "扶養費約定",
                "type": "textarea",
                "required": false,
                "placeholder": "例如：若有扶養費，可填寫扶養費金額及扶養費給付方式。若無扶養費，可填寫雙方無扶養費之約定。"
              },
              {
                "name": "propertyAgreement",
                "label": "夫妻財產約定",
                "type": "textarea",
                "required": false,
                "placeholder": "例如：若有財產，可填寫雙方財產各自所有，互不請求。若無財產，可填寫雙方無財產之約定。或填寫財產分配方式"
              },
              {
                "name": "otherAgreement",
                "label": "其他約定",
                "type": "textarea",
                "required": false,
                "placeholder": "請輸入其他約定事項。"
              },
              {
                "name": "documentDate",
                "label": "協議日期",
                "type": "date",
                "required": false
              }
            ]
          }
        ]
      }
    ]
  },
  "iou": {
    "title": "借據",
    "steps": [
      {
        "id": 1,
        "label": "填寫資料",
        "sections": [
          {
            "title": "出借人",
            "prefix": "lender",
            "fields": [
              {
                "name": "name",
                "label": "出借人姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：王小明"
              },
              {
                "name": "idNumber",
                "label": "出借人身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：A123456789"
              },
              {
                "name": "address",
                "label": "出借人地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "借款人",
            "prefix": "borrower",
            "fields": [
              {
                "name": "name",
                "label": "借款人姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：陳大明"
              },
              {
                "name": "idNumber",
                "label": "借款人身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：B223456789"
              },
              {
                "name": "address",
                "label": "借款人地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "借款內容",
            "prefix": "loan",
            "fields": [
              {
                "name": "amount",
                "label": "借款金額",
                "type": "number",
                "required": true,
                "placeholder": "例如：100000"
              },
              {
                "name": "loanDate",
                "label": "借款日期",
                "type": "date",
                "required": true
              },
              {
                "name": "dueDate",
                "label": "還款期限",
                "type": "date",
                "required": true
              },
              {
                "name": "interestRate",
                "label": "年利率（%）",
                "type": "number",
                "required": false,
                "placeholder": "例如：5"
              },
              {
                "name": "defaultInterestRate",
                "label": "違約利息（%）",
                "type": "number",
                "required": false,
                "placeholder": "例如：6"
              }
            ]
          },
          {
            "title": "借款交付方式",
            "prefix": "delivery",
            "fields": [
              {
                "name": "method",
                "label": "交付方式",
                "type": "select",
                "required": true,
                "options": [
                  {
                    "value": "",
                    "label": "請選擇"
                  },
                  {
                    "value": "cash",
                    "label": "現金交付"
                  },
                  {
                    "value": "transfer",
                    "label": "銀行轉帳"
                  },
                  {
                    "value": "remittance",
                    "label": "匯款"
                  },
                  {
                    "value": "check",
                    "label": "支票"
                  },
                  {
                    "value": "other",
                    "label": "其他"
                  }
                ]
              },
              {
                "name": "methodOther",
                "label": "其他交付方式",
                "type": "text",
                "required": false,
                "placeholder": "請輸入其他交付方式"
              },
              {
                "name": "delivered",
                "label": "借款已交付完成",
                "type": "checkbox",
                "required": false,
                "checkboxLabel": "借款已於簽署本借據時交付完成。"
              }
            ]
          },
          {
            "title": "其他",
            "prefix": "other",
            "fields": [
              {
                "name": "remark",
                "label": "備註",
                "type": "textarea",
                "required": false,
                "placeholder": "請輸入其他約定事項"
              },
              {
                "name": "signDate",
                "label": "簽署日期",
                "type": "date",
                "required": true
              }
            ]
          }
        ]
      }
    ]
  },
  "promissory-bill": {
    "title": "本票",
    "steps": [
      {
        "id": 1,
        "label": "填寫資料",
        "sections": [
          {
            "title": "受款人",
            "prefix": "payee",
            "fields": [
              {
                "name": "name",
                "label": "受款人姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：王小明"
              },
              {
                "name": "idNumber",
                "label": "受款人身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：A123456789"
              },
              {
                "name": "address",
                "label": "受款人地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "發票人",
            "prefix": "drawer",
            "fields": [
              {
                "name": "name",
                "label": "發票人姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：陳大明"
              },
              {
                "name": "idNumber",
                "label": "發票人身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：B223456789"
              },
              {
                "name": "address",
                "label": "發票人地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "本票內容",
            "prefix": "note",
            "fields": [
              {
                "name": "amount",
                "label": "本票金額",
                "type": "number",
                "required": true,
                "placeholder": "例如：100000"
              },
              {
                "name": "issueDate",
                "label": "發票日",
                "type": "date",
                "required": true
              },
              {
                "name": "dueType",
                "label": "到期方式",
                "type": "radio",
                "required": true,
                "options": [
                  {
                    "value": "fixed",
                    "label": "指定到期日"
                  },
                  {
                    "value": "on_demand",
                    "label": "見票即付"
                  }
                ]
              },
              {
                "name": "dueDate",
                "label": "到期日",
                "type": "date",
                "required": false
              },
              {
                "name": "issuePlace",
                "label": "發票地",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市"
              },
              {
                "name": "paymentPlace",
                "label": "付款地",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市"
              }
            ]
          },
          {
            "title": "利息條款",
            "prefix": "note",
            "fields": [
              {
                "name": "interestRate",
                "label": "年利率（%）",
                "type": "number",
                "required": false,
                "placeholder": "例如：5"
              },
              {
                "name": "interestStartDate",
                "label": "利息起算日",
                "type": "date",
                "required": false
              }
            ]
          },
          {
            "title": "票據條款",
            "prefix": "terms",
            "fields": [
              {
                "name": "waiveProtest",
                "label": "免除作成拒絕證書",
                "type": "checkbox",
                "required": false,
                "defaultChecked": true,
                "checkboxLabel": "免除作成拒絕證書"
              },
              {
                "name": "nonNegotiable",
                "label": "禁止背書轉讓",
                "type": "checkbox",
                "required": false,
                "defaultChecked": false,
                "checkboxLabel": "禁止背書轉讓"
              }
            ]
          },
          {
            "title": "備註",
            "prefix": "other",
            "fields": [
              {
                "name": "remark",
                "label": "備註",
                "type": "textarea",
                "required": false,
                "placeholder": "請輸入備註事項",
                "hint": "請勿填寫「符合特定條件才付款」等條件文字，以免影響票據效力。"
              }
            ]
          }
        ]
      }
    ]
  }
}