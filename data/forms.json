  "divorce": {
    "title": "離婚協議書",
    "steps": [
      {
        "id": 1,
        "label": "填寫資料",
        "sections": [
          {
            "title": "男方資料",
            "prefix": "husband",
            "fields": [
              {
                "name": "name",
                "label": "姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：王小明"
              },
              {
                "name": "idNumber",
                "label": "身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：A123456789"
              },
              {
                "name": "address",
                "label": "地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          {
            "title": "女方資料",
            "prefix": "wife",
            "fields": [
              {
                "name": "name",
                "label": "姓名",
                "type": "text",
                "required": true,
                "placeholder": "例如：陳小美"
              },
              {
                "name": "idNumber",
                "label": "身分證字號",
                "type": "text",
                "required": false,
                "placeholder": "例如：B223456789"
              },
              {
                "name": "address",
                "label": "地址",
                "type": "text",
                "required": false,
                "placeholder": "例如：臺中市西區○○路○○號"
              }
            ]
          },
          "fields": [
  {
    "name": "childrenAgreement",
    "label": "未成年子女約定",
    "type": "textarea",
    "required": false,
    "placeholder": "例如：雙方育有未成年子女王小明（110年1月1日生），由女方任主要照顧者，男方同意共同負擔扶養義務。若無未成年子女，可填寫：雙方無未成年子女。"
  },
  {
    "name": "supportAgreement",
    "label": "扶養費及探視約定",
    "type": "textarea",
    "required": false,
    "placeholder": "例如：男方每月5日前支付扶養費新臺幣15,000元至子女成年。男方每月第一、三週週六上午10時至週日下午6時得探視子女。"
  },
  {
    "name": "propertyChoice",
    "label": "夫妻財產及剩餘財產分配方式",
    "type": "select",
    "required": true,
    "options": [
      {
        "value": "",
        "label": "請選擇財產約定"
      },
      {
        "value": "mutual-waiver",
        "label": "雙方互不請求剩餘財產分配"
      },
      {
        "value": "completed",
        "label": "雙方已自行分配完成"
      },
      {
        "value": "custom",
        "label": "自行輸入財產分配方式"
      }
    ]
  },
  {
    "name": "propertyAgreement",
    "label": "自行約定財產分配內容",
    "type": "textarea",
    "required": false,
    "placeholder": "選擇「自行輸入」時，請填寫房屋、汽車、存款、保險、股票或其他財產的分配方式。"
  },
  {
    "name": "debtAgreement",
    "label": "債務約定",
    "type": "textarea",
    "required": false,
    "placeholder": "例如：雙方婚姻存續期間各自所負債務由各自負擔，他方不負連帶清償責任。"
  },
  {
    "name": "otherAgreement",
    "label": "其他約定",
    "type": "textarea",
    "required": false,
    "placeholder": "例如：雙方互不請求精神慰撫金、互不干涉生活、其他特別約定事項。"
  },
  {
    "name": "documentDate",
    "label": "立協議書日期",
    "type": "date",
    "required": false
  }
]